#!/usr/bin/env zsh
set -euo pipefail

# pid=$(port "$1" | awk '{print $2}')
# if [[ $pid ]]; then
#   kill -9 "$pid"
# else
#   echo "No process found on port ${1}"
# fi

pids=$(lsof -wni "tcp:$1" | awk 'NR>1 {print $2}')
if [[ -z "$pids" ]]; then
  echo "No process found on port $1"
  exit 1
fi
echo "$pids" | xargs kill
