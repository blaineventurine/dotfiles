#!/usr/bin/env zsh 
set -euo pipefail

sed 's/#.*//' "$HOME"/.default-npm-packages | grep -v '^\s*$' | xargs npm install -g
sed 's/#.*//' "$HOME"/.default-gems | grep -v '^\s*$' | xargs gem install
sed 's/#.*//' "$HOME"/.default-cargo-crates | grep -v '^\s*$' | xargs cargo install --force
# sed 's/#.*//' "$HOME"/.default-golang-pkgs | xargs go install
